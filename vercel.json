{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "rewrites": [
    {
      "source": "/answers/:slug",
      "destination": "/answers/:slug.html"
    },
    {
      "source": "/ask/:slug",
      "destination": "/ask/:slug.html"
    },
    {
      "source": "/compare/:slug",
      "destination": "/compare/:slug.html"
    },
    {
      "source": "/define/:slug",
      "destination": "/define/:slug.html"
    },
    {
      "source": "/local/:slug",
      "destination": "/local/:slug.html"
    },
    {
      "source": "/aeo-master",
      "destination": "/aeo-master.html"
    }
  ]
}